# ─── Database ────────────────────────────────────────────────────────────────
# MongoDB connection string (required)
DATABASE_URL="mongodb+srv://user:password@cluster.mongodb.net/zenbourg?retryWrites=true&w=majority"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Required — generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# ─── Email (Optional — uses Resend) ──────────────────────────────────────────
# Get your key at https://resend.com
# If not set, emails are logged to console (dev mode)
RESEND_API_KEY=""
EMAIL_FROM="Zenbourg <noreply@yourdomain.com>"

# ─── SMS / WhatsApp (Optional — uses Twilio) ─────────────────────────────────
# If not set, SMS/WhatsApp are logged to console (mock mode)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1234567890"
TWILIO_VERIFY_SERVICE_SID=""
TWILIO_WHATSAPP_NUMBER="+14155238886"

# ─── Payments (Optional — uses Razorpay) ─────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── CORS (Optional) ─────────────────────────────────────────────────────────
# Restrict API CORS to specific origin in production
# ALLOWED_ORIGIN="https://yourapp.com"
