// Zenbourg Hotel Management System - Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ========================================
// USERS & AUTHENTICATION
// ========================================

model User {
  id         String     @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  email      String     @unique
  phone      String     @unique
  password   String
  role       UserRole
  status     UserStatus @default(ACTIVE)
  dndEnabled Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workplaceId String?   @db.ObjectId
  myWorkplace Property? @relation("WorkerRelation", fields: [workplaceId], references: [id])

  ownedPropertyIds String[]   @db.ObjectId
  ownedProperties  Property[] @relation("OwnershipRelation", fields: [ownedPropertyIds], references: [id])
  staffProfile     Staff?

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  HOTEL_ADMIN
  MANAGER
  RECEPTIONIST
  STAFF
  GUEST
}

enum UserStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

// ========================================
// GUESTS
// ========================================

model Guest {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String?
  phone           String    @unique
  idType          String?
  idNumber        String?
  idDocumentFront String?
  idDocumentBack  String?
  address         String?
  dateOfBirth     DateTime?

  checkInStatus      CheckInStatus @default(PENDING)
  checkInCompletedAt DateTime?

  language String @default("English")

  // Track which property created/owns this guest profile
  createdByPropertyId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings        Booking[]
  serviceRequests ServiceRequest[]
  supportTickets  SupportTicket[]
  ratings         Rating[]
  favorites       Favorite[]

  lostItems LostItem[]

  @@map("guests")
}

model Favorite {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  guestId String @db.ObjectId
  guest   Guest  @relation(fields: [guestId], references: [id], onDelete: Cascade)

  roomId String @db.ObjectId
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([guestId, roomId])
  @@map("favorites")
}

enum CheckInStatus {
  PENDING
  LINK_SENT
  LINK_OPENED
  COMPLETED
  VERIFIED
}

// ========================================
// PROPERTIES & ROOMS
// ========================================

model Property {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  address     String
  phone       String
  email       String
  logo        String?
  coverImage  String?
  images      String[]

  // Operating Hours
  checkInTime  String @default("14:00")
  checkOutTime String @default("11:00")

  // Policies
  cancellationPolicy String?
  // Subscription Model
  plan               SubscriptionPlan @default(BASE)
  features           String[]         @default(["BASIC_OPS", "STAFF_MANAGEMENT"])
  planExpiresAt      DateTime?

  latitude  Float?
  longitude Float?
  ranking   Int    @default(0) // Higher value = better ranking/SEO
  policies  Json? // Flexible JSON for various policies

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownerIds String[] @db.ObjectId
  owners   User[]   @relation("OwnershipRelation", fields: [ownerIds], references: [id])

  workerList      User[]           @relation("WorkerRelation")
  rooms           Room[]           @relation("PropertyToRoom")
  amenities       Amenity[]        @relation("PropertyToAmenity")
  menuItems       MenuItem[]       @relation("PropertyToMenuItem")
  spaServices     SpaService[]     @relation("PropertyToSpaService")
  staff           Staff[]          @relation("PropertyToStaff")
  bookings        Booking[]        @relation("PropertyToBooking")
  serviceRequests ServiceRequest[] @relation("PropertyToServiceRequest")
  rolePermissions RolePermission[] @relation("PropertyToRolePermission")
  serviceConfigs  ServiceConfig[]  @relation("PropertyToServiceConfig")
  campaigns       Campaign[]       @relation("PropertyToCampaign")
  systemNodes     SystemNode[]     @relation("PropertyToSystemNode")
  systemAlerts    SystemAlert[]    @relation("PropertyToSystemAlert")
  supportTickets  SupportTicket[]  @relation("PropertyToSupportTicket")
  lostItems       LostItem[]       @relation("PropertyToLostItem")

  @@map("properties")
}

model Room {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToRoom", fields: [propertyId], references: [id], onDelete: Cascade)

  roomNumber String
  floor      Int
  category   RoomCategory
  type       String // Standard King, Deluxe Twin, etc.

  maxOccupancy     Int
  basePrice        Float
  weekendSurcharge Float @default(0)

  visibleOnline  Boolean @default(true)
  petFriendly    Boolean @default(false)
  smokingAllowed Boolean @default(false)
  adaCompliant   Boolean @default(false)

  amenities   String[]
  images      String[]
  description String?

  status RoomStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  bookings        Booking[]
  serviceRequests ServiceRequest[]
  favorites       Favorite[]
  lostItems       LostItem[]

  @@unique([propertyId, roomNumber])
  @@index([propertyId])
  @@index([status])
  @@map("rooms")
}

enum RoomCategory {
  STANDARD
  DELUXE
  SUITE
  PENTHOUSE
  CUSTOM
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  BLOCKED
  CLEANING
}

// ========================================
// BOOKINGS
// ========================================

model Booking {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  guestId String @db.ObjectId
  guest   Guest  @relation(fields: [guestId], references: [id])

  roomId String @db.ObjectId
  room   Room   @relation(fields: [roomId], references: [id])

  checkIn  DateTime
  checkOut DateTime

  actualCheckIn  DateTime?
  actualCheckOut DateTime?

  numberOfGuests Int

  status BookingStatus @default(RESERVED)
  source BookingSource @default(DIRECT)

  totalAmount   Float
  paidAmount    Float         @default(0)
  paymentStatus PaymentStatus @default(PENDING)

  // Tax & Charges breakdown (applied at booking time from PropertySettings)
  baseAmount           Float? // Room rate × nights (before tax)
  gstPercent           Float? // GST % applied
  gstAmount            Float? // GST amount
  serviceChargePercent Float? // Service charge %
  serviceChargeAmount  Float? // Service charge amount
  luxuryTaxPercent     Float? // Luxury tax %
  luxuryTaxAmount      Float? // Luxury tax amount
  discountPercent      Float? // Discount %
  discountAmount       Float? // Discount amount
  finalAmount          Float? // totalAmount after all taxes & discounts

  specialRequests String?
  notes           String?

  propertyId String?   @db.ObjectId
  property   Property? @relation("PropertyToBooking", fields: [propertyId], references: [id])

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  lostItems LostItem[]

  @@index([propertyId])
  @@index([status])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

enum BookingStatus {
  RESERVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
}

enum BookingSource {
  WALK_IN
  DIRECT
  BOOKING_COM
  MAKE_MY_TRIP
  AGODA
  EXPEDIA
  AIRBNB
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  REFUNDED
}

// ========================================
// SERVICES & ORDERS
// ========================================

model ServiceRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  type ServiceType

  guestId String? @db.ObjectId
  guest   Guest?  @relation(fields: [guestId], references: [id])

  roomId String? @db.ObjectId
  room   Room?   @relation(fields: [roomId], references: [id])

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToServiceRequest", fields: [propertyId], references: [id])

  title       String
  description String?
  priority    Priority @default(NORMAL)

  assignedToId String? @db.ObjectId
  assignedTo   Staff?  @relation(fields: [assignedToId], references: [id])

  status ServiceStatus @default(PENDING)

  // SLA Tracking
  slaMinutes  Int       @default(60) // Default 60 minutes
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  // Payment (for food orders)
  amount        Float?
  paymentStatus PaymentStatus?

  attachments String[]
  notes       String?

  updatedAt DateTime @updatedAt

  // Relations
  ratings  Rating[]
  messages Message[] @relation("ServiceMessages")

  @@index([propertyId])
  @@index([status])
  @@index([type])
  @@index([assignedToId])
  @@map("service_requests")
}

enum ServiceType {
  HOUSEKEEPING
  FOOD_ORDER
  ROOM_SERVICE
  LAUNDRY
  MAINTENANCE
  CONCIERGE
  SPA
}

enum ServiceStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ========================================
// STAFF & HR
// ========================================

model Staff {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @unique @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToStaff", fields: [propertyId], references: [id], onDelete: Cascade)

  employeeId    String    @unique
  dateOfBirth   DateTime?
  dateOfJoining DateTime  @default(now())

  department   Department
  designation  String
  contractType String?    @default("Full-Time Permanent")
  workShift    String?    @default("Morning (06:00 - 14:00)")
  managerName  String?    @default("Michael Scott")

  // Compensation
  baseSalary    Float
  bankName      String?
  accountNumber String?
  ifscCode      String?

  // Emergency Contact
  emergencyContactName  String?
  emergencyContactPhone String?

  address      String?
  profilePhoto String?
  documents    Json? // Store various documents

  // Leave Balances
  annualLeaveBalance Int @default(15)
  sickLeaveBalance   Int @default(10)
  casualLeaveBalance Int @default(7)

  isVerified            Boolean @default(false)
  verificationRequested Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendances       Attendance[]
  leaveRequests     LeaveRequest[]
  serviceRequests   ServiceRequest[]
  payrolls          Payroll[]
  performanceScores PerformanceScore[]
  lostItems         LostItem[]

  @@index([propertyId])
  @@index([department])
  @@map("staff")
}

enum Department {
  FRONT_DESK
  HOUSEKEEPING
  KITCHEN
  ROOM_SERVICE
  MAINTENANCE
  SECURITY
  ACCOUNTS
  MANAGEMENT
}

// ========================================
// ATTENDANCE
// ========================================

model Attendance {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  staffId String @db.ObjectId
  staff   Staff  @relation(fields: [staffId], references: [id])

  date DateTime

  punchIn  DateTime?
  punchOut DateTime?

  punchInLocation  String?
  punchOutLocation String?

  status AttendanceStatus @default(ABSENT)

  // Working Hours
  hoursWorked   Float?
  overtimeHours Float  @default(0)

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, date])
  @@index([date])
  @@map("attendances")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

// ========================================
// LEAVE MANAGEMENT
// ========================================

model LeaveRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  staffId String @db.ObjectId
  staff   Staff  @relation(fields: [staffId], references: [id])

  leaveType LeaveType
  startDate DateTime
  endDate   DateTime
  totalDays Int

  reason String

  status LeaveStatus @default(PENDING)

  approvedBy String?
  approvedAt DateTime?

  rejectionReason String?
  evidence        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_requests")
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ========================================
// PAYROLL & INCENTIVES
// ========================================

model Payroll {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  staffId String @db.ObjectId
  staff   Staff  @relation(fields: [staffId], references: [id])

  month String // Format: YYYY-MM
  year  Int

  // Salary Components
  baseSalary  Float
  overtimePay Float @default(0)
  incentives  Float @default(0)
  bonuses     Float @default(0)
  deductions  Float @default(0)
  netSalary   Float

  // Status
  status    PayrollStatus @default(PENDING)
  paidAt    DateTime?
  paymentId String?

  // Calculations Breakdown
  breakdown Json? // Detailed breakdown of calculations
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, month, year])
  @@map("payrolls")
}

enum PayrollStatus {
  PENDING
  APPROVED
  PAID
}

// ========================================
// PERFORMANCE & RATINGS
// ========================================

model Rating {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  guestId String @db.ObjectId
  guest   Guest  @relation(fields: [guestId], references: [id])

  serviceRequestId String?         @db.ObjectId
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id])

  // Can be for service or overall stay
  type RatingType

  rating  Int // 1-5
  comment String?

  createdAt DateTime @default(now())

  @@map("ratings")
}

enum RatingType {
  SERVICE
  OVERALL_STAY
  CLEANLINESS
  FOOD
  STAFF
}

model PerformanceScore {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  staffId String @db.ObjectId
  staff   Staff  @relation(fields: [staffId], references: [id])

  month String // Format: YYYY-MM
  year  Int

  // Metrics
  tasksCompleted Int    @default(0)
  tasksOnTime    Int    @default(0)
  avgRating      Float?
  slaBreaches    Int    @default(0)

  // Calculated Score
  overallScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, month, year])
  @@map("performance_scores")
}

// ========================================
// HOTEL CONTENT
// ========================================

model Amenity {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToAmenity", fields: [propertyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  icon        String?
  category    String? // Pool, Gym, Spa, etc.
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("amenities")
}

model MenuItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToMenuItem", fields: [propertyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String // Breakfast, Lunch, Dinner, Beverages
  cuisine     String? // Indian, Chinese, Continental, etc.

  price  Float
  margin Float    @default(0)
  images String[]

  isVeg       Boolean @default(true)
  isAvailable Boolean @default(true)

  prepTime Int? // In minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("menu_items")
}

model SpaService {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToSpaService", fields: [propertyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  duration    Int // In minutes
  price       Float
  image       String?

  isAvailable Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("spa_services")
}

model LostItem {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToLostItem", fields: [propertyId], references: [id], onDelete: Cascade)

  name        String
  description String?
  category    String // ELECTRONICS, CLOTHING, PERSONAL, etc.
  status      String  @default("FOUND") // FOUND, CLAIMED, DISPOSED

  foundDate DateTime @default(now())
  location  String?

  roomId String? @db.ObjectId
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  reportedById String? @db.ObjectId
  reportedBy   Staff?  @relation(fields: [reportedById], references: [id], onDelete: SetNull)

  // Guest & Booking for tracking
  guestId   String?  @db.ObjectId
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  bookingId String?  @db.ObjectId
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  image          String? // Primary Thumbnail
  evidenceImages String[]
  caseNotes      Json? // List of {note: string, author: string, createdAt: Date}

  // Claim Details
  claimerName  String?
  claimerPhone String?
  claimedAt    DateTime?
  claimNotes   String?

  // WhatsApp Automation
  whatsappSent      Boolean   @default(false)
  whatsappSentAt    DateTime?
  whatsappStatus    String?
  whatsappMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lost_items")
}

// ========================================
// SYSTEM CONFIGURATION
// ========================================

model RolePermission {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToRolePermission", fields: [propertyId], references: [id], onDelete: Cascade)

  role        UserRole
  permissions Json // Map of permissions: { "rooms": "READ_WRITE", "payroll": "NONE", etc. }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([propertyId, role])
  @@map("role_permissions")
}

model SystemSetting {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  key         String  @unique
  value       String
  description String?

  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model NotificationTemplate {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  name    String              @unique
  type    NotificationType
  channel NotificationChannel

  subject  String? // For email
  template String // Template content with variables

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification_templates")
}

model ServiceConfig {
  id         String        @id @default(auto()) @map("_id") @db.ObjectId
  propertyId String        @db.ObjectId
  property   Property      @relation("PropertyToServiceConfig", fields: [propertyId], references: [id], onDelete: Cascade)
  type       ServiceType
  steps      ServiceStep[]
  totalSla   Int // Total SLA in minutes
  options    Json? // Dynamic options for guests (e.g. types of cleaning)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([propertyId, type])
  @@map("service_configs")
}

model ServiceStep {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  serviceConfigId String        @db.ObjectId
  serviceConfig   ServiceConfig @relation(fields: [serviceConfigId], references: [id], onDelete: Cascade)
  name            String // e.g., "Cooking", "Staff Transfer"
  duration        Int // Duration in minutes
  order           Int // Position in the path

  @@map("service_steps")
}

enum NotificationType {
  CHECK_IN_LINK
  BOOKING_CONFIRMATION
  CHECK_IN_REMINDER
  CHECK_OUT_REMINDER
  SERVICE_REQUEST_UPDATE
  PAYMENT_RECEIPT
  STAFF_TASK_ASSIGNED
  LEAVE_APPROVED
  SALARY_CREDITED
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
  PUSH
  IN_APP
}

model Campaign {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  description String?
  startedAt   DateTime            @default(now())
  segment     String // e.g., "Diamond Only", "Platinum & Above"
  performance Int                 @default(0) // Percentage or some metric
  status      CampaignStatus      @default(ACTIVE)
  channel     NotificationChannel
  promoCode   String?
  propertyId  String              @db.ObjectId
  property    Property            @relation("PropertyToCampaign", fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("campaigns")
}

enum CampaignStatus {
  ACTIVE
  SCHEDULED
  COMPLETED
  CANCELLED
}

model SystemNode {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  type       String // Retail Hardware, Network Layer, Wi-Fi Access Point, Smart Hub
  ipAddress  String
  uptime     String
  status     String // Online, Offline, High Load, Disconnected
  propertyId String   @db.ObjectId
  property   Property @relation("PropertyToSystemNode", fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_nodes")
}

model SystemAlert {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  message     String
  description String?
  type        String // CRITICAL, WARNING, INFO
  timestamp   DateTime @default(now())
  category    String // POS, Wi-Fi, IoT, Channel Manager
  propertyId  String   @db.ObjectId
  property    Property @relation("PropertyToSystemAlert", fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("system_alerts")
}

// ========================================
// NOTIFICATIONS & MESSAGING
// ========================================

model InAppNotification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String
  type        String   @default("INFO") // INFO, ALERT, TASK, SYSTEM
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, isRead])
  @@map("in_app_notifications")
}

model Message {
  id         String  @id @default(auto()) @map("_id") @db.ObjectId
  senderId   String  @db.ObjectId
  receiverId String? @db.ObjectId // Optional if it's a room/service chat

  serviceRequestId String?         @db.ObjectId
  serviceRequest   ServiceRequest? @relation("ServiceMessages", fields: [serviceRequestId], references: [id])

  content   String
  isRead    Boolean  @default(false)
  type      String   @default("TEXT") // TEXT, IMAGE, DOCUMENT
  category  String   @default("CHAT") // ADMIN, GUEST, TEAM
  createdAt DateTime @default(now())

  @@index([receiverId, isRead])
  @@map("messages")
}

enum SubscriptionPlan {
  BASE
  STARTER
  STANDARD
  ENTERPRISE
  // Legacy values kept for backward compatibility with existing DB records
  GOLD
  PLATINUM
  DIAMOND
}

// ========================================
// SUPPORT TICKETS
// ========================================

model SupportTicket {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  guestId String @db.ObjectId
  guest   Guest  @relation(fields: [guestId], references: [id])

  propertyId String?   @db.ObjectId
  property   Property? @relation("PropertyToSupportTicket", fields: [propertyId], references: [id])

  type     TicketType
  subject  String
  message  String
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(NORMAL)

  messages TicketMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_tickets")
}

model TicketMessage {
  id       String        @id @default(auto()) @map("_id") @db.ObjectId
  ticketId String        @db.ObjectId
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId   String @db.ObjectId // Guest or Admin User ID
  senderRole String // GUEST, ADMIN, OWNER

  content   String
  createdAt DateTime @default(now())

  @@map("ticket_messages")
}

// ========================================
// SUBSCRIPTION DEFS (Super Admin Only)
// ========================================

model PlanDefinition {
  id   String           @id @default(auto()) @map("_id") @db.ObjectId
  plan SubscriptionPlan @unique

  // Display
  displayName String? // "Base", "Starter", "Standard", "Enterprise"
  tagline     String? // "For independent properties getting started"
  description String?

  // Pricing
  originalPrice   Float  @default(0) // Strikethrough price
  discountedPrice Float  @default(0) // Actual charge
  discountPercent Float  @default(0) // % off (editable by super admin)
  billingCycle    String @default("monthly") // monthly | yearly

  // Limits
  maxRooms Int @default(30) // 0 = unlimited
  maxStaff Int @default(10) // 0 = unlimited

  // Features included
  features String[]

  updatedAt DateTime @updatedAt

  @@map("plan_definitions")
}

// Per-property financial settings (editable by hotel admin)
model PropertySettings {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  propertyId String @unique @db.ObjectId

  // Tax & Charges
  gstPercent           Float @default(18.0)
  serviceChargePercent Float @default(0.0)
  luxuryTaxPercent     Float @default(0.0)

  // Discount
  defaultDiscountPercent Float   @default(0.0)
  discountLabel          String? @default("Discount")

  // Invoice
  invoicePrefix String  @default("INV")
  invoiceFooter String?

  // Currency
  currency       String @default("INR")
  currencySymbol String @default("₹")

  // Check-in/out
  checkInTime  String @default("14:00")
  checkOutTime String @default("11:00")

  // Bank Account (for Razorpay payouts to hotel owner)
  bankAccountName   String? // Account holder name
  bankAccountNumber String? // Account number
  bankIfscCode      String? // IFSC code
  bankName          String? // Bank name e.g. HDFC, SBI
  bankBranch        String? // Branch name
  upiId             String? // UPI ID for quick payments

  // Property-specific Razorpay credentials (override global keys)
  razorpayKeyId     String? // Razorpay Key ID
  razorpayKeySecret String? // Razorpay Key Secret (handle with care)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("property_settings")
}

enum TicketType {
  TECHNICAL
  BOOKING
  PAYMENT
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
}
